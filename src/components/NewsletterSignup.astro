---
import { site } from "../data/site";

interface Props {
  compact?: boolean;
  source?: string;
}

const { compact = false, source = "site" } = Astro.props;
const formId = `ai-news-signup-form-${source}`;
const statusId = `ai-news-signup-status-${source}`;
---

<section class={`card ${compact ? "p-4" : "p-5 sm:p-6"}`} aria-labelledby={`ai-news-signup-${source}`}>
  <div class="flex flex-col gap-4">
    <div>
      <p class="text-[11px] font-semibold uppercase mb-2" style={`color: var(--text-tertiary); letter-spacing: 0;`}>
        Daily AI News
      </p>
      <h2 id={`ai-news-signup-${source}`} class={`${compact ? "text-base" : "text-lg"} font-bold tracking-tight mb-2`} style={`color: var(--text-primary);`}>
        Subscribe to {site.newsletter.name}
      </h2>
      <p class="text-xs leading-[1.8]" style={`color: var(--text-secondary);`}>
        {site.newsletter.description}
      </p>
    </div>

    <form
      id={formId}
      action="/api/ai-news-subscribe"
      method="post"
      class="flex flex-col sm:flex-row gap-2"
      data-newsletter-subscribe-form
      data-newsletter-source={source}
      aria-describedby={statusId}
    >
      <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
      <div class="flex-1">
        <label for={`email-${source}`} class="sr-only">Email address</label>
        <input
          id={`email-${source}`}
          name="email"
          type="email"
          autocomplete="email"
          required
          placeholder="you@example.com"
          class="w-full min-h-11 px-3 py-2 rounded-xl text-sm outline-none"
          style={`background: var(--bg-secondary); color: var(--text-primary); border: 1px solid var(--border-color);`}
        />
      </div>
      <button
        type="submit"
        class="min-h-11 px-4 rounded-xl text-sm font-semibold cursor-pointer transition-all hover:opacity-90"
        style={`background: var(--color-accent); color: white;`}
      >
        Subscribe
      </button>
    </form>
    <p
      id={statusId}
      class="text-[11px] leading-relaxed"
      style={`color: var(--text-tertiary);`}
      role="status"
      aria-live="polite"
      data-newsletter-subscribe-status
    />

    <p class="text-[11px] leading-relaxed" style={`color: var(--text-tertiary);`}>
      No spam. Every issue links back to the original sources.
    </p>
  </div>
</section>

<script>
  if (!window.__aiNewsKitSignupBound) {
    window.__aiNewsKitSignupBound = true;

    document.addEventListener("submit", async (event) => {
      const form = event.target;
      if (!(form instanceof HTMLFormElement) || !form.matches("[data-newsletter-subscribe-form]")) {
        return;
      }

      event.preventDefault();

      const emailInput = form.querySelector('input[name="email"]');
      const websiteInput = form.querySelector('input[name="website"]');
      const submitButton = form.querySelector('button[type="submit"]');
      const status = form.parentElement?.querySelector("[data-newsletter-subscribe-status]");
      const source = form.dataset.newsletterSource ?? "site";

      if (!(emailInput instanceof HTMLInputElement) || !(submitButton instanceof HTMLButtonElement)) {
        return;
      }

      if (!emailInput.reportValidity()) {
        return;
      }

      const originalButtonText = submitButton.textContent ?? "Subscribe";
      submitButton.disabled = true;
      submitButton.textContent = "Subscribing...";
      if (status) {
        status.textContent = "";
      }

      try {
        const response = await fetch(form.action, {
          method: "POST",
          headers: {
            "Content-Type": "application/json; charset=utf-8",
          },
          body: JSON.stringify({
            email: emailInput.value,
            source,
            website: websiteInput instanceof HTMLInputElement ? websiteInput.value : "",
          }),
        });

        if (!response.ok) {
          throw new Error(`Kit returned ${response.status}`);
        }

        emailInput.value = "";
        if (status) {
          status.textContent = "Subscribed. Check your inbox if confirmation is required.";
        }
      } catch (error) {
        console.error(error);
        if (status) {
          status.textContent = "Subscription is not available yet. Please try again later.";
        }
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = originalButtonText;
      }
    });
  }
</script>
