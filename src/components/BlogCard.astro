---
interface Props {
  title: string;
  date: string;
  description: string;
  slug: string;
  basePath?: string;
}

const { title, date, description, slug, basePath = "/blog" } = Astro.props;
---

<a
  href={`${basePath}/${slug}`}
  class="group card block p-5"
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <h3 class="text-sm font-semibold mb-1.5 group-hover:text-[var(--color-accent)] transition-colors" style={`color: var(--text-primary);`}>
        {title}
      </h3>
      <p class="text-xs leading-relaxed line-clamp-2" style={`color: var(--text-secondary);`}>
        {description}
      </p>
    </div>
    <time class="text-[10px] font-mono whitespace-nowrap pt-0.5" style={`color: var(--text-tertiary);`}>
      {date}
    </time>
  </div>
</a>
