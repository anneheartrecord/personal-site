---
import { socials } from "../data/socials";
import { hero } from "../data/hero";

const navLinks = [
  { href: "/", label: "Home", icon: "home" },
  { href: "/projects", label: "Projects", icon: "projects" },
  { href: "/blog", label: "Blog", icon: "blog" },
  { href: "/social", label: "Social Media", icon: "social" },
];

const sidebarSocials = socials.filter((s) => s.showInSidebar);
---

<!-- Mobile menu button -->
<button
  id="mobile-menu-btn"
  class="fixed top-4 left-4 z-50 lg:hidden p-2 rounded-xl shadow-sm"
  style={`background-color: var(--card-bg); border: 1px solid var(--border-color); color: var(--text-primary);`}
  aria-label="Menu"
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>

<!-- Mobile overlay -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/30 backdrop-blur-sm z-30 hidden lg:hidden"></div>

<!-- Sidebar -->
<aside
  id="sidebar"
  class="fixed top-0 left-0 h-screen w-64 z-40 flex flex-col -translate-x-full lg:translate-x-0 transition-transform duration-300"
  style={`background-color: var(--sidebar-bg); border-right: 1px solid var(--border-color);`}
>
  <!-- Profile section -->
  <div class="px-6 pt-8 pb-6">
    <a href="/" class="block mb-4">
      <img
        src={hero.avatar}
        alt={hero.name}
        class="w-28 h-28 rounded-2xl object-cover"
        style={`border: 3px solid var(--border-color); box-shadow: 0 4px 16px rgba(0,0,0,0.08);`}
      />
    </a>
    <h2 class="text-base font-bold mb-0.5" style={`color: var(--text-primary);`}>{hero.name}</h2>
    <p class="text-[11px]" style={`color: var(--text-tertiary);`}>{hero.nameCN}</p>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-3">
    <ul class="space-y-1">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-[13px] font-medium transition-all duration-150"
              style={`color: var(--text-secondary);`}
              data-nav-link
            >
              {link.icon === "home" && (
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
              )}
              {link.icon === "projects" && (
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
              )}
              {link.icon === "blog" && (
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                </svg>
              )}
              {link.icon === "social" && (
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.914-3.022a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                </svg>
              )}
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- Bottom: socials -->
  <div class="px-6 pb-6">
    <div class="flex items-center gap-4">
      {
        sidebarSocials.map((social) => (
          social.icon === "wechat" ? (
            <button
              class="wechat-trigger p-1.5 rounded-lg transition-all duration-200 hover:scale-110 hover:bg-[var(--bg-tertiary)] cursor-pointer"
              style={`color: var(--text-tertiary); background: none; border: none;`}
              title={social.name}
            >
              <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.045c.134 0 .24-.11.24-.245 0-.06-.024-.12-.04-.178l-.325-1.233a.492.492 0 01.177-.554C23.028 18.553 24 16.803 24 14.861c0-3.089-2.757-5.9-7.062-6.003zm-2.745 2.254c.534 0 .967.44.967.982a.975.975 0 01-.967.981.975.975 0 01-.967-.981c0-.542.433-.982.967-.982zm4.842 0c.534 0 .967.44.967.982a.975.975 0 01-.967.981.975.975 0 01-.967-.981c0-.542.433-.982.967-.982z"/></svg>
            </button>
          ) : (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="p-1.5 rounded-lg transition-all duration-200 hover:scale-110 hover:bg-[var(--bg-tertiary)]"
              style={`color: var(--text-tertiary);`}
              title={social.name}
            >
              {social.icon === "github" && (
                <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              )}
              {social.icon === "twitter" && (
                <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              )}
              {social.icon === "email" && (
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              )}
            </a>
          )
        ))
      }
    </div>
    <p class="text-[10px] mt-4" style={`color: var(--text-tertiary); opacity: 0.6;`}>
      &copy; {new Date().getFullYear()} Charles
    </p>
  </div>
</aside>

<!-- WeChat QR Modal -->
<div id="wechat-modal" class="fixed inset-0 z-[100] hidden items-center justify-center" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);">
  <div class="card p-6 mx-4 flex flex-col items-center animate-[fadeIn_0.2s_ease]" style="max-width: 320px;">
    <img src="/images/wechat.jpg" alt="WeChat QR Code" class="w-64 rounded-2xl" style={`border: 2px solid var(--border-color); box-shadow: 0 4px 16px rgba(0,0,0,0.08);`} />
    <button id="wechat-modal-close" class="mt-5 px-5 py-2 rounded-xl text-xs font-medium cursor-pointer transition-all duration-200 hover:bg-[var(--bg-tertiary)]" style={`color: var(--text-tertiary); border: 1px solid var(--border-color);`}>Close</button>
  </div>
</div>

<script>
  const modal = document.getElementById("wechat-modal")!;
  const closeBtn = document.getElementById("wechat-modal-close")!;

  // All wechat triggers (sidebar + hero)
  document.querySelectorAll(".wechat-trigger").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    });
  });

  closeBtn.addEventListener("click", () => {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  });

  modal.addEventListener("click", (e) => {
    if (e.target === modal) {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }
  });
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }
</style>
