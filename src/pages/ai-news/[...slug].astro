---
import Layout from "../../layouts/Layout.astro";
import NewsletterSignup from "../../components/NewsletterSignup.astro";
import { getCollection, render } from "astro:content";
import { site } from "../../data/site";

export async function getStaticPaths() {
  const issues = await getCollection("aiNews", ({ data }) => !data.draft);
  return issues.map((issue) => ({
    params: { slug: issue.id },
    props: { issue },
  }));
}

const { issue } = Astro.props;
const { Content } = await render(issue);
const publishedDate = issue.data.date.toISOString();
const canonicalPath = `/ai-news/${issue.id}`;
---

<Layout
  title={`${issue.data.title} — Charles Cheng`}
  description={issue.data.description}
  canonicalPath={canonicalPath}
  pageType="article"
  lang="zh-CN"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: issue.data.title,
    description: issue.data.description,
    datePublished: publishedDate,
    dateModified: publishedDate,
    url: new URL(canonicalPath, site.url).toString(),
    keywords: issue.data.tags,
    author: {
      "@type": "Person",
      name: site.author.name,
      alternateName: site.author.alias,
      url: site.url,
    },
    publisher: {
      "@type": "Person",
      name: site.author.name,
      alternateName: site.author.alias,
      url: site.url,
    },
  }}
>
  <article>
    <a href="/ai-news" class="inline-flex items-center text-xs font-medium mb-6 transition-opacity hover:opacity-70" style={`color: var(--text-tertiary);`}>
      ← Back to AI News
    </a>

    <header class="mb-8">
      <p class="text-[11px] font-semibold uppercase mb-3" style={`color: var(--text-tertiary); letter-spacing: 0;`}>
        Daily AI News
      </p>
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight mb-3" style={`color: var(--text-primary);`}>
        {issue.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-3">
        <time class="text-xs font-mono" style={`color: var(--text-tertiary);`}>
          {issue.data.date.toISOString().split("T")[0]}
        </time>
        <div class="flex flex-wrap gap-1.5">
          {issue.data.tags.map((tag: string) => <span class="tag-pill">{tag}</span>)}
          <span class="tag-pill">{issue.data.sourceCount} sources</span>
        </div>
      </div>
    </header>

    <div class="prose"><Content /></div>

    <div class="mt-12">
      <NewsletterSignup source={`ai-news-${issue.id}`} />
    </div>

    <div class="mt-12 pt-6" style={`border-top: 1px solid var(--border-color);`}>
      <a href="/ai-news" class="text-xs font-medium transition-opacity hover:opacity-70" style={`color: var(--color-accent);`}>← Back to AI News</a>
    </div>
  </article>
</Layout>
