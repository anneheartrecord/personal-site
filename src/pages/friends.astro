---
import Layout from "../layouts/Layout.astro";
import { friends } from "../data/friends";
---

<Layout title="Friends — Charles">
  <h1 class="text-2xl font-bold tracking-tight mb-2" style={`color: var(--text-primary);`}>Friends</h1>
  <p class="text-sm mb-8" style={`color: var(--text-secondary);`}>Cool people I know on the internet.</p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    {friends.map((friend) => (
      <a
        href={friend.url}
        target="_blank"
        rel="noopener noreferrer"
        class="card p-5 flex items-center gap-4 group"
      >
        <img
          src={friend.avatar}
          alt={friend.name}
          class="w-12 h-12 rounded-xl object-cover shrink-0"
          style={`border: 1px solid var(--border-color);`}
        />
        <div class="min-w-0">
          <h3 class="text-sm font-semibold group-hover:text-[var(--color-accent)] transition-colors" style={`color: var(--text-primary);`}>
            {friend.name}
          </h3>
          <p class="text-xs truncate" style={`color: var(--text-tertiary);`}>
            {friend.description}
          </p>
        </div>
      </a>
    ))}
  </div>
</Layout>
